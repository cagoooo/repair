rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ============================
    // 🗺️ 地圖圖片
    // ============================
    match /map-images/{imageId} {
      // 任何人可讀取
      allow read: if true;
      // 僅管理員可上傳，與前端共用 10MB 限制、僅限圖片
      allow write: if request.auth != null
        && request.auth.token.email == 'ipad@mail2.smes.tyc.edu.tw'
        && request.resource.size <= 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ============================
    // 📄 教室配置來源 PDF（選用）
    // ============================
    match /map-source-pdfs/{pdfId} {
      allow read: if request.auth != null
        && request.auth.token.email == 'ipad@mail2.smes.tyc.edu.tw';
      allow write: if request.auth != null
        && request.auth.token.email == 'ipad@mail2.smes.tyc.edu.tw'
        && request.resource.size <= 10 * 1024 * 1024
        && request.resource.contentType == 'application/pdf';
    }

    // ============================
    // 📸 報修圖片
    // ============================
    match /repair-images/{allPaths=**} {
      // 任何人可讀取（查看報修照片）
      allow read: if true;
      // 上傳限制：僅限圖片、單檔 ≤ 2MB
      allow write: if request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ============================
    // 🚫 預設拒絕
    // ============================
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
